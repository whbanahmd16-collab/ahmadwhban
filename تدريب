                    {!recordedVideoUrl ? (
                        !isRecording ? <button onClick={startRecording} className="flex-1 py-4 bg-[#00d2ff] text-black font-black rounded-xl text-xs uppercase italic tracking-widest"><Play size={16} className="inline mr-2" /> ابدأ التسجيل</button>
                        : <button onClick={stopRecording} className="flex-1 py-4 bg-red-600 text-white font-black rounded-xl text-xs uppercase italic animate-pulse"><StopCircle size={16} className="inline mr-2" /> إيقاف وحفظ</button>
                    ) : (
                        <button onClick={() => { setIsRecordingModalOpen(false); setRecordedVideoUrl(null); }} className="flex-1 py-4 bg-[#00d2ff] text-black font-black rounded-xl text-xs uppercase italic tracking-widest">تم الحفظ</button>
                    )}
                </div>
            </div>
        </div>
      )}
    </div>
  );

  return (
    <div className="min-h-screen bg-[#020617] font-sans">
      {currentView === 'landing' ? <LandingPage /> : currentView === 'login' ? (
        <div className="min-h-screen bg-[#020617] flex items-center justify-center p-6" dir="rtl">
          <div className="w-full max-w-sm bg-[#0f172a] rounded-[2.5rem] p-10 text-center shadow-2xl border border-white/5">
            <h2 className="text-2xl font-black italic text-white mb-8">منصة <span className="text-[#00d2ff]">الأبطال</span></h2>
            <input type="text" value={accessCode} onChange={(e) => setAccessCode(e.target.value)} className="w-full bg-black/40 border border-white/10 rounded-xl py-4 text-center text-2xl font-black text-[#00d2ff] mb-6 outline-none" placeholder="XXXX" />
            <button onClick={handleLogin} className="w-full bg-[#00d2ff] text-black font-black py-4 rounded-xl text-xs uppercase italic tracking-widest">دخول</button>
            <button onClick={() => setCurrentView('landing')} className="mt-4 text-gray-500 text-[10px] font-black uppercase italic hover:text-white">الرجوع</button>
          </div>
        </div>
      ) : <Dashboard />}
      
      {/* CV Modal - Simplified for robustness */}
      {isCVModalOpen && (
        <div className="fixed inset-0 z-[100] flex items-center justify-center p-6 bg-black/95 backdrop-blur-xl" onClick={() => setIsCVModalOpen(false)}>
          <div className="w-full max-w-2xl bg-[#0f172a] rounded-[3rem] p-10 overflow-y-auto max-h-[80vh] text-right" onClick={e => e.stopPropagation()}>
            <h2 className="text-3xl font-black text-white mb-6 italic">أحمد وهبان</h2>
            <div className="space-y-4">
              <div className="bg-white/5 p-6 rounded-2xl border border-white/5"><h4 className="text-[#00d2ff] font-black text-lg italic">مدرب شخصي معترف به (CPT)</h4><p className="text-gray-400 text-xs mt-2">وزارة الرياضة - المملكة العربية السعودية</p></div>
              <div className="bg-white/5 p-6 rounded-2xl border border-white/5"><h4 className="text-[#00d2ff] font-black text-lg italic">أخصائي قوة وتكيف (S&C)</h4><p className="text-gray-400 text-xs mt-2">منظمة IFA الدولية</p></div>
              <div className="bg-white/5 p-6 rounded-2xl border border-white/5"><h4 className="text-[#00d2ff] font-black text-lg italic">بكالوريوس إدارة خدمات طبية</h4><p className="text-gray-400 text-xs mt-2">جامعة الملك عبدالعزيز</p></div>
            </div>
            <button onClick={() => setIsCVModalOpen(false)} className="mt-8 w-full py-4 bg-white/5 text-gray-400 font-black rounded-xl italic">إغلاق</button>
          </div>
        </div>
      )}

      <style>{`
        @import url('https://fonts.googleapis.com/css2?family=Tajawal:wght@400;700;900&display=swap');
        body { font-family: 'Tajawal', sans-serif; }
        .hero-gradient { background: radial-gradient(circle at top right, #0c4a6e 0%, #020617 75%); }
        .no-scrollbar::-webkit-scrollbar { display: none; }
        @keyframes fade-in { from { opacity: 0; transform: translateY(20px); } to { opacity: 1; transform: translateY(0); } }
        .animate-fade-in { animation: fade-in 0.8s ease-out forwards; }
      `}</style>
    </div>
  );
};

export default App;
